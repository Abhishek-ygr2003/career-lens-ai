# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Naukri.com Scraper Configuration (Optional - fallback instructions printed if blank/expired)
NAUKRI_NKPARAM=your-nkparam-from-browser-devtools
NAUKRI_COOKIE=your-cookie-header-from-browser-devtools

# Google Gemini API Key (Optional — enables AI Insights tab in the dashboard)
# Get a free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Adzuna API Configuration (Get free keys from developer.adzuna.com)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
